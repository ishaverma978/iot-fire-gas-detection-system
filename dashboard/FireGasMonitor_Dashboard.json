{
    "widgets": [
        {
            "type": "text",
            "x": 0,
            "y": 0,
            "width": 24,
            "height": 2,
            "properties": {
                "markdown": "# 🔥 FireGasMonitor — Real-Time IoT Safety Dashboard\n**Project PUG020** &nbsp;|&nbsp; NodeMCU/ESP8266 + MQ2 Gas Sensor + Flame Sensor &nbsp;|&nbsp; ✅ 3-Zone Detection (Safe / Warning / Danger) &nbsp;|&nbsp; ✅ IFTTT Alerts (SMS + Email + App) &nbsp;|&nbsp; ✅ Auto Safety Response (Buzzer + Fan + LED)"
            }
        },
        {
            "type": "metric",
            "x": 0,
            "y": 2,
            "width": 4,
            "height": 4,
            "properties": {
                "title": "🌡 Gas Level (Live)",
                "view": "singleValue",
                "stat": "Average",
                "period": 10,
                "metrics": [
                    [ "FireGasMonitor", "GasAnalogLevel" ]
                ],
                "annotations": {
                    "horizontal": [
                        {
                            "label": "Danger",
                            "value": 650,
                            "color": "#E24B4A",
                            "fill": "above"
                        }
                    ]
                },
                "sparkline": true,
                "liveData": true,
                "region": "ap-south-1"
            }
        },
        {
            "type": "metric",
            "x": 4,
            "y": 2,
            "width": 4,
            "height": 4,
            "properties": {
                "title": "🔥 Flame Detected",
                "view": "singleValue",
                "stat": "Maximum",
                "period": 10,
                "metrics": [
                    [ "FireGasMonitor", "FlameStatus" ]
                ],
                "annotations": {
                    "horizontal": [
                        {
                            "label": "Fire!",
                            "value": 0.5,
                            "color": "#E24B4A",
                            "fill": "above"
                        }
                    ]
                },
                "sparkline": true,
                "liveData": true,
                "region": "ap-south-1"
            }
        },
        {
            "type": "metric",
            "x": 8,
            "y": 2,
            "width": 4,
            "height": 4,
            "properties": {
                "title": "💨 Gas Leaked",
                "view": "singleValue",
                "stat": "Maximum",
                "period": 10,
                "metrics": [
                    [ "FireGasMonitor", "GasDetected" ]
                ],
                "annotations": {
                    "horizontal": [
                        {
                            "label": "Gas Leak!",
                            "value": 0.5,
                            "color": "#E24B4A",
                            "fill": "above"
                        }
                    ]
                },
                "sparkline": true,
                "liveData": true,
                "region": "ap-south-1"
            }
        },
        {
            "type": "metric",
            "x": 12,
